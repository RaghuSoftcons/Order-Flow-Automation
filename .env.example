# File:        .env.example
# Created:     2026-04-26 17:19 EST
# Last Modified: 2026-04-26 17:19 EST
#
# Copy to .env for local dev. Production values live in Railway Variables.
# NEVER commit .env to git.

# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# --- Auth ---
# Random string used to hash per-user API keys. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_SALT=replace_with_random_secret

# --- Database ---
# Local dev defaults to SQLite at ./data/orderflow.db.
# In Railway, attach Postgres plugin and Railway sets DATABASE_URL automatically.
DATABASE_URL=

# --- Cache ---
# Local dev uses fakeredis (in-process). In Railway, attach Redis plugin and
# Railway sets REDIS_URL automatically.
REDIS_URL=

# --- Anthropic ---
# Used for Claude smoke tests during Phase 0 and tool calls in Phase 2+.
# Store in Railway Variables, never in source control.
ANTHROPIC_API_KEY=

# --- Schwab (Phase 4) ---
# Wired from existing Schwab integration project; populated later.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_TOKEN_STORE_PATH=
